# Copy to .env and fill in. The app runs fully WITHOUT these (rule-based AI fallback).
PORT=4000
JWT_SECRET=change-me-in-production-please

# Optional: enable real Claude-powered multilingual extraction.
# Get a key at https://console.anthropic.com. Without it, the offline rule-based engine is used.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Speech-to-text for the "Start meeting" live recorder (auto language detection / code-mixing).
# Supported: "none" (default, browser-only), "sarvam", "openai", "groq"
TRANSCRIPTION_PROVIDER=none

# Sarvam AI — best for Telugu/Hindi/English + code-mixing. Get a key at https://dashboard.sarvam.ai
SARVAM_API_KEY=
SARVAM_MODEL=saarika:v2.5

# OpenAI Whisper (TRANSCRIPTION_PROVIDER=openai, paid) or Groq Whisper (=groq).
# Groq has a FREE tier and runs Whisper large-v3 (multilingual, auto-detect) —
# get a free key at https://console.groq.com → API Keys, then set
# TRANSCRIPTION_PROVIDER=groq and GROQ_API_KEY below.
OPENAI_API_KEY=
GROQ_API_KEY=

# ---- Daily task digest ----
# Primary channel: Zoho Cliq. In Cliq: open the target channel → settings → Integrations
# → Incoming Webhook → create one → copy the Webhook URL here. Restart the server after.
# While blank, the digest runs in PREVIEW mode (prints to the server console).
CLIQ_WEBHOOK_URL=
# Hour (0-23, local server time) the daily digest is sent. Default 8 = 8:00 AM.
DIGEST_HOUR=8

# Optional per-person email (only used if SMTP is filled in).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Befach Task Manager <no-reply@befach.com>
